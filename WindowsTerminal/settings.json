{
    // 修改默认Profile
    // "defaultProfile": guid,
    "launchMode": "maximized",
    "compatibility": {
        "enableUnfocusedAcrylic": true
    },
    "showTabsInTitlebar": true,
    "useAcrylicInTabRow": true,
    "copyFormatting": "none",
    "copyOnSelect": false,
    "actions": [],
    "keybindings": [],
    "profiles": {
        "defaults": {
            "font": {
                "face": "JetBrainsMono Nerd Font",
                "features": { "rlig": 1 },
                "size": 16
            },
            "opacity": 80,
            "useAcrylic": true,
            "hidden": false,
            "closeOnExit": "automatic"
        },
        "list": []
    }
}


