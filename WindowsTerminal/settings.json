{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "defaultProfile": "{b6d28cf0-b245-59cb-a780-b728ed6c082e}",
    "disabledProfileSources": [
        "Windows.Terminal.Wsl",
        "Windows.Terminal.Azure",
        "Windows.Terminal.PowershellCore",
        "Windows.Terminal.SSH"
    ],
    "keybindings": [],
    "launchMode": "maximized",
    "newTabMenu": [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": {
        "defaults": {
            "closeOnExit": "automatic",
            "font": {
                "face": "JetBrainsMono Nerd Font",
                "features": {
                    "rlig": 1
                },
                "size": 16
            },
            "hidden": false,
            "opacity": 80,
            "useAcrylic": true
        },
        "list": [
            {
                "commandline": "pwsh.exe -wd ~",
                "guid": "{b6d28cf0-b245-59cb-a780-b728ed6c082e}",
                "name": "Pwsh"
            },
            {
                "commandline": "wsl.exe -d Debian --cd ~",
                "guid": "{f1778049-a679-5200-9578-9cc2369f73ed}",
                "name": "Debian"
            },
            {
                "commandline": "%ProgramFiles%\\Git\\bin\\bash.exe -li",
                "guid": "{d15b228a-05d7-50d1-8472-f60aaba86efc}",
                "name": "Git Bash",
                "startingDirectory": "%USERPROFILE%"
            },
            {
                "commandline": "powershell.exe",
                "guid": "{e72abb56-ab17-50cf-9780-9bbd9b2b850c}",
                "name": "PowerShell",
                "startingDirectory": "%USERPROFILE%"
            },
            {
                "commandline": "cmd.exe",
                "guid": "{9d434cee-6d5a-544b-bafa-db22607aae28}",
                "name": "CommandPrompt",
                "startingDirectory": "%USERPROFILE%"
            }
        ]
    },
    "schemes": [],
    "showTabsInTitlebar": true,
    "themes": [],
    "useAcrylicInTabRow": false
}
